generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  VENDOR
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AssetStatus {
  IN_USE
  IN_STORE
  IN_REPAIR
  RETIRED
  DAMAGED
  NON_FUNCTIONAL
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum ReplacementStatus {
  PENDING
  COMPLETED
}

enum UserRole {
  ADMIN
  INSPECTION_OFFICER
  DEPARTMENT_HEAD
  PROJECT_MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InspectionPriority {
  LOW
  MEDIUM
  HIGH
}


model User {
  id        String   @id @default(uuid())

  name      String
  email     String   @unique
  password  String

  mobileNumber String?
  designation  String?

  status    UserStatus @default(ACTIVE)

  lastLogin DateTime?

  role      Role @default(USER)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  assetMappings AssetMapping[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id          String   @id @default(uuid())

  name        String   @unique

  purpose     String?
  location    String?
  city        String?
  state       String?
  pincode     String?

  // NEW FIELDS
  code        String?   @unique
  description String?
  adminName   String?

  totalStaff  Int       @default(0)
  totalAssets Int       @default(0)

  isActive    Boolean   @default(true)

  // transfer relations
  transfersFrom AssetTransfer[] @relation("FromDepartment")

  transfersTo   AssetTransfer[] @relation("ToDepartment")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  users       User[]

  replacements AssetReplacement[]

  complaints   Complaint[]

  mappings     AssetMapping[]
}

model Vendor {
  id              String   @id @default(uuid())
  companyName     String   @unique

  // contact
  contactNumber   String
  whatsappNumber  String?
  email           String
  website         String?

  // person
  fullName        String?

  // address
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  pincode         String?

  // business
  gstNumber       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products        Product[]
  bankDetails     VendorBankDetails?  
  documents       VendorDocument[]
  complaints      Complaint[]

}

model VendorBankDetails {
  id            String @id @default(uuid())

  vendorId      String @unique
  vendor        Vendor @relation(fields: [vendorId], references: [id])

  accountName   String
  accountNumber String
  bankName      String
  branchCode    String?
  ifscCode      String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VendorDocument {
  id        String @id @default(uuid())

  vendorId  String
  vendor    Vendor @relation(fields: [vendorId], references: [id])

  fileUrl   String
  fileType  String

  createdAt DateTime @default(now())
}
 
model Product {
  id                  String   @id @default(uuid())

  // Product Info
  productName         String
  quantity            Int
  serialNumber        String?

  // Dates
  procurementDate     DateTime
  warrantyExpiryDate  DateTime?

  // Extra
  amcAvailable        Boolean
  invoiceNumber       String?

  unitPrice Float?
  status AssetStatus?

  // Relations
  departmentId        String
  department          Department @relation(fields: [departmentId], references: [id])

  vendorId            String
  vendor              Vendor @relation(fields: [vendorId], references: [id])

  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id])

  transfers           AssetTransfer[]

  mappings AssetMapping[]


  complaints          Complaint[]
  projectAssets ProjectAsset[]
  inspections Inspection[]

  oldReplacements AssetReplacement[] @relation("OldProductReplacement")

  newReplacements AssetReplacement[] @relation("NewProductReplacement")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AssetReplacement {
  id String @id @default(uuid())

  // old product
  oldProductId String
  oldProduct   Product @relation("OldProductReplacement",fields: [oldProductId],references: [id])

  // new product
  newProductId String
  newProduct   Product @relation("NewProductReplacement",fields: [newProductId],references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId],references: [id])

  reason String?

  replacedBy String

  status ReplacementStatus @default(COMPLETED)

  replacementDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetTransfer {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  fromDepartmentId String?
  fromDepartment   Department? @relation("FromDepartment", fields: [fromDepartmentId], references: [id])

  toDepartmentId String?
  toDepartment   Department? @relation("ToDepartment", fields: [toDepartmentId], references: [id])

  transferredBy String
  approvedBy    String?

  reason String?

  status TransferStatus @default(PENDING)

  transferDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model AssetMapping {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  assignedDate DateTime @default(now())

  returnedDate DateTime?

  isActive Boolean @default(true)

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
}


model Complaint {
  id                  String   @id @default(uuid())

  title               String
  description         String?
  urgency             Urgency

  // department
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id])
  departmentName      String?

  fullName            String
  designation         String?
  contactNumber       String
  email               String
  location            String?

  // vendor
  vendorId            String?
  vendor              Vendor? @relation(fields: [vendorId], references: [id])
  vendorCompanyName   String?
  vendorContactName   String?
  vendorContactNumber String?
  vendorWhatsapp      String?
  vendorEmail         String?
  vendorLocation String?

  // product
  productId           String?
  product             Product? @relation(fields: [productId], references: [id])
  productName         String?

  category            String?
  otherProduct        String?
  serialNumber        String?
  amcContractNumber   String?

  warrantyExpiryDate  DateTime?
  issueDate           DateTime

  // communication
  sendWhatsapp        Boolean @default(false)
  sendEmail           Boolean @default(false)

  // lifecycle
  status              ComplaintStatus @default(OPEN)
  resolvedAt          DateTime?

  attachments         ComplaintAttachment[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ComplaintAttachment {
  id          String   @id @default(uuid())

  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  fileUrl     String
  fileType    String

  createdAt   DateTime @default(now())
}

model Project {
  id              String   @id @default(uuid())

  projectId       String?   @unique
  projectName     String

  category        String
  schemeName      String?

  projectType     String

  department      String

  priorityLevel   String?

  status          String   @default("Pending")

  progress        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt



  // relations

  location         ProjectLocation?
  description      ProjectDescription?
  timeline         ProjectTimeline?
  budget           ProjectBudget?
  vendor           ProjectVendor?

  assets           ProjectAsset[]
  inspections Inspection[]

  milestones       ProjectMilestone[]

  team             ProjectTeam?

  approvals        ProjectApproval[]
}

model ProjectLocation {

  id          String @id @default(uuid())

  projectId   String? @unique

  state       String?
  district    String
  block       String
  ward        String

  address     String?

  project     Project? @relation(fields: [projectId],references: [id])
}

model ProjectDescription {

  id            String @id @default(uuid())

  projectId     String? @unique

  description   String

  scope         String?

  fileUrl       String?

  project       Project? @relation(fields: [projectId],references: [id])
}


model ProjectTimeline {

  id          String @id @default(uuid())

  projectId   String? @unique

  startDate   DateTime

  endDate     DateTime

  project     Project? @relation(fields: [projectId],references: [id])
}


model ProjectBudget {

  id                String @id @default(uuid())

  projectId         String? @unique

  totalBudget       Float

  fundingSource     String?

  expenseBreakdown  String?

  project           Project? @relation(fields: [projectId],references: [id])
}

model ProjectVendor {

  id              String @id @default(uuid())

  projectId       String? @unique

  vendorName      String

  companyName     String?

  contactDetails  String?

  contractValue   Float?

  agreementFile   String?

  project         Project? @relation(fields: [projectId],references: [id])
}

model ProjectAsset {

  id          String @id @default(uuid())

  projectId   String?

  productId   String

  project     Project? @relation(fields: [projectId],references: [id])

  product     Product? @relation(fields: [productId],references: [id] )
}

model ProjectMilestone {

  id            String @id @default(uuid())

  projectId     String?

  milestoneName String

  dueDate       DateTime

  budgetPercent Float?

  status        String @default("Pending")

  project       Project? @relation(fields: [projectId],references: [id])
}

model ProjectTeam {

  id                String @id @default(uuid())

  projectId         String? @unique

  projectManager    String

  supervisor        String?

  departmentHead    String?

  project           Project? @relation(fields: [projectId],references: [id])
}

model ProjectApproval {

  id            String @id @default(uuid())

  projectId     String?

  levelName     String

  isApproved    Boolean @default(false)

  approvedBy    String?

  approvedAt    DateTime?

  order         Int

  project       Project? @relation(fields: [projectId],references: [id])
}

model Inspection {

  id String @id @default(uuid())

  inspectionId String @unique

  title String

  type String?

  priority String?

  status String?

  scheduledDate DateTime?

  reminderDate DateTime?

  location String?

  inspectorName String?

  notes String?
  reports InspectionReport[]

  projectId String?

  project Project? @relation(fields: [projectId], references: [id])

  productId String?

  product Product? @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}


model InspectionReport {

  id String @id @default(uuid())

  inspectionId String

  inspection Inspection @relation(fields: [inspectionId],references: [id])

  observation String

  complianceStatus String

  recommendation String?

  inspectionResult String

  latitude String?

  longitude String?

  address String?

  photoUrls String[]

  videoUrls String[]

  signatureUrl String?

  supervisorStatus String @default("PENDING")

supervisorComment String?

approvedBy String?

approvedAt DateTime?

  status String @default("SUBMITTED")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}